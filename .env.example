# Core mode
GMAIL_MODE=gmail_api
GMAIL_POLL_INTERVAL_SECONDS=60

# Storage
# For Vercel/shared hosting, prefer DATABASE_URL=postgres://...
DATABASE_URL=
# Optional fallback when inbound emails do not contain scan+<user_id>@...
# Use only for single-tenant testing.
DEFAULT_USER_ID=
INTAKE_DB_PATH=data/intake.db
INTAKE_RAW_DIR=data/raw
APPROVED_SENDERS_FILE=approved_senders.json

# Gmail API mode (preferred)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_USER=me
GMAIL_QUERY=is:unread newer_than:7d
GMAIL_LABEL_PROCESSED=processed
GMAIL_API_RATE_LIMIT_PER_SEC=5
GMAIL_API_MAX_RETRIES=5
GMAIL_API_BACKOFF_BASE_SECONDS=1
GMAIL_API_BACKOFF_MAX_SECONDS=30

# IMAP fallback mode
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_PROCESSED_FOLDER=Processed

# Logging
LOG_LEVEL=INFO
